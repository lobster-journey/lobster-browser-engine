{
  "name": "lobster-browser-engine: jimeng_login",
  "version": "1.0.0",
  "description": "即梦AI抖音登录流程",
  "success_rate": "100%",
  "author": "龙虾智能体",
  "created_at": "2026-04-19",
  "tags": ["login", "jimeng", "douyin"],
  
  "params": {
    "wait_qr_code": {
      "type": "number",
      "default": 30,
      "description": "等待扫码时间（秒）"
    }
  },
  
  "steps": [
    {
      "step_id": 1,
      "action": "press",
      "key": "F5",
      "wait_after": 3,
      "description": "刷新页面确保状态干净",
      "retry": 1
    },
    {
      "step_id": 2,
      "action": "click",
      "locator": "css=#SiderMenuLogin > div > div",
      "wait_after": 2,
      "description": "点击登录按钮",
      "retry": 3,
      "on_failure": "截图并发送错误信息"
    },
    {
      "step_id": 3,
      "action": "click",
      "locator": "css=.lv-menu-item.lv-menu-item-size-default.login-menu-item-Yoy61o",
      "wait_after": 3,
      "description": "点击抖音登录按钮",
      "retry": 3,
      "notes": "抖音登录按钮选择器可能变化，需要动态查找"
    },
    {
      "step_id": 4,
      "action": "wait",
      "time": 3,
      "description": "等待二维码弹窗加载"
    },
    {
      "step_id": 5,
      "action": "screenshot",
      "description": "截图当前二维码状态"
    },
    {
      "step_id": 6,
      "action": "evaluate",
      "script": "const refreshBtn = await page.locator('text=刷新').first(); if (await refreshBtn.count() > 0) { await refreshBtn.click(); }",
      "wait_after": 2,
      "description": "检查并点击刷新按钮（如果二维码失效）",
      "optional": true
    },
    {
      "step_id": 7,
      "action": "screenshot",
      "description": "最终截图"
    }
  ],
  
  "success_criteria": {
    "type": "url_not_contains",
    "value": "login",
    "description": "URL不再包含login字样"
  },
  
  "notes": [
    "二维码弹窗需要等待加载（2-3秒）",
    "Playwright locator API 比 DOM 搜索更可靠",
    "截图必须保存到本地文件再发送",
    "使用 locator('text=刷新') 定位刷新按钮最可靠"
  ],
  
  "verified_count": 3,
  "last_verified": "2026-04-19"
}
